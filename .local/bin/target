if [ -f target ]; then
	cat target
	cp target ~/ 2>/dev/null
elif [ -f targets ]; then
	cat targets
	cp targets ~/ 2>/dev/null
elif [ -f ~/targets ]; then
	cat ~/targets
elif [ -f ~/target ]; then
	cat ~/target
elif [ -f `cat ~/workingdirectory`/target ]; then
	cat `cat ~/workingdirectory`/target
fi
