#!/usr/bin/env bash
#set -euo pipefail

REMOTE_URL="${1:?usage: dot-bootstrap-remote <git-remote-url> [host...]}"
shift || true

if [ "$#" -eq 0 ]; then
  mapfile -t HOSTS < "$HOME/.config/dotfiles/hosts"
else
  HOSTS=("$@")
fi

for host in "${HOSTS[@]}"; do
  [ -z "$host" ] && continue
  echo "==> bootstrapping $host"
  scp "$HOME/.local/bin/dot-remote-setup.sh" "$host:/tmp/dot-remote-setup.sh"
  ssh "$host" "bash /tmp/dot-remote-setup.sh '$REMOTE_URL' && rm -f /tmp/dot-remote-setup.sh"
done
