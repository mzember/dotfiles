#!/usr/bin/env bash
set -euo pipefail

host="${1:?usage: dot-import-added-from-host <host>}"

# staged files on remote, with status
mapfile -t entries < <(
  ssh "$host" 'export PATH="$HOME/.local/bin:$PATH"; dot diff --cached --name-status'
)

if [ "${#entries[@]}" -eq 0 ]; then
  echo "No staged files on $host"
  exit 0
fi

echo "Staged on $host:"
printf '  %s\n' "${entries[@]}"
echo

files_to_add=()
files_to_remove=()

for entry in "${entries[@]}"; do
  status="${entry%%$'\t'*}"
  file="${entry#*$'\t'}"

  case "$status" in
    A|M)
      mkdir -p "$HOME/$(dirname "$file")"
      scp "$host:~/$file" "$HOME/$file"
      files_to_add+=("$HOME/$file")
      ;;
    D)
      files_to_remove+=("$HOME/$file")
      ;;
    *)
      echo "Skipping unsupported staged status: $entry" >&2
      ;;
  esac
done

if [ "${#files_to_add[@]}" -gt 0 ]; then
  dot add "${files_to_add[@]}"
fi

if [ "${#files_to_remove[@]}" -gt 0 ]; then
  dot rm -- "${files_to_remove[@]}"
fi

echo "Imported from $host."
echo "Review with: dot diff --cached"
echo "Publish with: dotsync \"import from $host\""
