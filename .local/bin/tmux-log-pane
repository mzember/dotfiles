#!/usr/bin/env bash
set -euo pipefail

logdir="$HOME/script-logs"
mkdir -p "$logdir"

log_one() {
  local pane="$1"
  local ts sess win pidx
  ts="$(date +%F.%H-%M-%S)"
  sess="$(tmux display -p -t "$pane" '#{session_name}')"
  win="$(tmux display -p -t "$pane" '#{window_index}')"
  pidx="$(tmux display -p -t "$pane" '#{pane_index}')"

  tmux pipe-pane -o -t "$pane" "cat >> \"$logdir/tmux.$ts.$sess.w$win.p$pidx.log\""
}

if [[ $# -ge 1 ]]; then
  log_one "$1"
else
  tmux list-panes -a -F '#{pane_id}' | while read -r p; do
    log_one "$p"
  done
fi
