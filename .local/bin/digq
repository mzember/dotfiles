#!/usr/bin/env bash

name="$1"
shift

if echo "$name" | grep -q '\..*\.'; then
  echo "Hint: Test the domain without subdomain as well"
fi

if [ -z "$name" ]; then
  echo "Usage: digq <domain>"
  exit 1
fi

types=(A AAAA CNAME TXT NS MX)

for t in "${types[@]}"; do
  echo "== $t =="
  set -x
  /usr/bin/dig "$name" "$t" +noall +answer
  set +x
  echo
done
